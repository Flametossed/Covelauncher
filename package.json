{
  "name": "covelauncher",
  "private": true,
  "version": "1.0.0",
  "description": "Game library manager",
  "author": "Duck912",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/Duck912/CoveLauncher.git"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && tsc -p electron/tsconfig.json && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "compression": "maximum",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-web/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "appId": "com.covelauncher.app",
    "mac": {
      "icon": "public/logo.png"
    },
    "win": {
      "icon": "public/logo.png",
      "target": ["portable"]
    },
    "linux": {
      "icon": "public/logo.png",
      "target": ["AppImage"]
    }
  },
  "dependencies": {
    "axios": "^1.15.1",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "extract-zip": "^2.0.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  }
}